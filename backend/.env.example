# Copy this file to .env and fill in your values

# Server port
PORT=5000

# MongoDB connection string
# Local MongoDB:
MONGO_URI=mongodb://127.0.0.1:27017/restaurant_erp
# Or MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/restaurant_erp

# Secret used to sign JWT tokens (change this to any long random string)
JWT_SECRET=change_this_to_a_long_random_secret_string

# How long a login session stays valid
JWT_EXPIRES_IN=7d

# Comma-separated frontend URLs allowed by Express and Socket.IO CORS
CLIENT_URLS=http://localhost:5173,https://restaurant-erp-1-v70d.onrender.com

# Optional local diagnostics logging. Keep false in production unless debugging.
DEBUG_API=false

# Legacy single-origin fallback still supported by server.js:
# CLIENT_URL=http://localhost:5173
