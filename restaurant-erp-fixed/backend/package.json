{
  "name": "restaurant-erp-backend",
  "version": "1.0.0",
  "description": "Restaurant ERP System - MERN backend (MongoDB, Express, Node)",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
